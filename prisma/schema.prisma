generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  BRAND
  CREATOR
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  userType      UserType  @default(BRAND)
  brandId       String?
  brand         Brand?    @relation(fields: [brandId], references: [id])
  emailVerified DateTime?
  creatorProfile CreatorProfile?
  creatorProposals Proposal[] @relation("CreatorProposals")
  verificationTokens VerificationToken[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CreatorProfile {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instagramHandle       String?
  instagramScopedUserId String?  @unique
  instagramAvatarUrl    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

/// One-time tokens for creator magic links and post-OAuth session handoff.
model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Brand {
  id                     String                  @id @default(uuid())
  companyName            String
  slug                   String                  @unique
  instagramBusinessId    String?                 @unique
  users                  User[]
  campaigns              Campaign[]
  instagramConnection    InstagramConnection?
  instagramConversations InstagramConversation[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model Campaign {
  id       String  @id @default(uuid())
  brandId  String
  brand    Brand   @relation(fields: [brandId], references: [id])
  name     String
  slug     String
  isActive Boolean @default(false)

  minFollowers      Int
  minEngagementRate Decimal @db.Decimal(5, 2)

  baseRatePer10kCents    Int
  ratePerReelCents       Int
  ratePerStoryCents      Int
  adUsage30DayMultiplier Decimal @db.Decimal(5, 2)
  adUsage90DayMultiplier Decimal @db.Decimal(5, 2)

  proposalDrafts         ProposalDraft[]
  proposals              Proposal[]
  instagramConversations InstagramConversation[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@unique([brandId, slug])
}

model ProposalDraft {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  creatorHandle String
  creatorName   String?
  creatorEmail  String?

  followerCount      Int
  engagementRate     Decimal @db.Decimal(5, 2)
  enrichmentProvider String  @default("mock")
  enrichmentPayload  Json?

  source ProposalSource @default(WEB)

  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Proposal {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  creatorHandle String
  creatorName   String?
  creatorEmail  String?

  followerCount      Int
  engagementRate     Decimal @db.Decimal(5, 2)
  enrichmentProvider String  @default("mock")
  enrichmentPayload  Json?

  reelsCount   Int
  storiesCount Int
  adUsageDays  Int

  calculatedPayoutCents Int
  matchTier             MatchTier
  workflowStatus        WorkflowStatus @default(NEW)

  source                ProposalSource @default(WEB)
  instagramScopedUserId String?

  contactedAt DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  adminNotes  String?

  events                ProposalEvent[]
  instagramConversation InstagramConversation?
  creatorUserId         String?
  creatorUser           User?                  @relation("CreatorProposals", fields: [creatorUserId], references: [id])
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model ProposalEvent {
  id         String            @id @default(uuid())
  proposalId String
  proposal   Proposal          @relation(fields: [proposalId], references: [id])
  type       ProposalEventType
  metadata   Json?
  createdAt  DateTime          @default(now())
}

enum MatchTier {
  GREEN
  YELLOW
  ARCHIVED
}

enum WorkflowStatus {
  NEW
  CONTACTED
  APPROVED
  REJECTED
}

enum ProposalEventType {
  CREATED
  CONTACTED
  APPROVED
  REJECTED
  STATUS_CHANGED
  EMAIL_OPENED
  EXPORTED
  DM_SENT
  DM_RECEIVED
  INSTAGRAM_REPLY
  CONVERSATION_STARTED
}

enum ProposalSource {
  WEB
  INSTAGRAM_DM
}

/// One Instagram Professional account per brand (Instagram-Login API path).
model InstagramConnection {
  id      String @id @default(uuid())
  brandId String @unique
  brand   Brand  @relation(fields: [brandId], references: [id])

  igUserId       String  @unique
  igUsername     String?
  accessTokenEnc String // AES-256-GCM ciphertext; never logged

  tokenExpiresAt    DateTime?
  webhookSubscribed Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// DM conversation state, one row per (brand, IG sender, campaign).
model InstagramConversation {
  id                    String @id @default(uuid())
  brandId               String
  brand                 Brand  @relation(fields: [brandId], references: [id])
  campaignId            String
  campaign              Campaign @relation(fields: [campaignId], references: [id])
  instagramScopedUserId String

  state        String // InstagramConversationState in the app layer
  draftMetrics Json? // { followerCount, engagementRate } snapshot
  draftScope   Json? // { reelsCount, storiesCount, adUsageDays }
  draftId      String? // FK-by-id to a reused ProposalDraft row

  // Optimistic-concurrency guard: transitions do a conditional update on version.
  version Int @default(0)

  lastInboundAt  DateTime
  lastOutboundAt DateTime?
  expiresAt      DateTime?

  proposalId String?   @unique
  proposal   Proposal? @relation(fields: [proposalId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([brandId, instagramScopedUserId, campaignId])
}
